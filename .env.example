# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 절대 커밋하지 마세요(.gitignore 처리됨).

# --- kokalim: Supabase (운영 DB — docs/db-schema.md §4.3) ---
# 값 얻는 곳: supabase.com 대시보드 → 프로젝트 → 상단 "Connect" 버튼
# DATABASE_URL        = "Transaction pooler" 접속 문자열 (포트 6543) — api/workers 런타임용
# DIRECT_DATABASE_URL = "Direct connection" 접속 문자열 (포트 5432) — 마이그레이션/DDL용
# [YOUR-PASSWORD] 자리는 DB 비밀번호로 치환 (분실 시: Settings → Database → Reset database password)
DATABASE_URL=
DIRECT_DATABASE_URL=
# (선택, 지금은 불필요) 서버에서 supabase-js를 쓰게 될 때만: Settings → API Keys → service_role
# SUPABASE_SERVICE_ROLE_KEY=

# --- kokalim: 텔레그램 알림 (BotFather로 새 봇 생성) ---
NEWSBOT_TELEGRAM_BOT_TOKEN=
NEWSBOT_TELEGRAM_CHAT_ID=

# --- kokalim: 네이버 뉴스검색 API (developers.naver.com, 앱에 "검색" API 추가 필수) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- method_b: KRX 데이터 (data.krx.co.kr 무료 가입) ---
KRX_ID=
KRX_PW=

# --- (선택) LLM 백엔드를 codex 대신 Anthropic API로 쓸 때만 ---
# ANTHROPIC_API_KEY=

# --- (선택) 카카오 '나에게 보내기' 발송 ---
# KAKAO_ACCESS_TOKEN=
