# 이 파일을 .env 로 복사한 뒤 값을 채우세요. .env 는 절대 커밋하지 마세요(.gitignore 처리됨).

# --- news_bot: 텔레그램 알림 (BotFather로 새 봇 생성) ---
NEWSBOT_TELEGRAM_BOT_TOKEN=
NEWSBOT_TELEGRAM_CHAT_ID=

# --- news_bot: 네이버 뉴스검색 API (developers.naver.com, 앱에 "검색" API 추가 필수) ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- method_b: KRX 데이터 (data.krx.co.kr 무료 가입) ---
KRX_ID=
KRX_PW=

# --- (선택) Supabase sink: `--sink supabase`로 Vercel 푸시 구성을 쓸 때만 ---
# 로컬은 이 두 개만 필요(쓰기용 service_role 키 — RLS 우회, 절대 커밋 금지).
# 나머지 시크릿(웹훅/텔레그램)은 Vercel 대시보드 환경변수에 설정. 상세: vercel/README.md
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=

# --- (선택) LLM 백엔드를 codex 대신 Anthropic API로 쓸 때만 ---
# ANTHROPIC_API_KEY=

# --- (선택) 카카오 '나에게 보내기' 발송 ---
# KAKAO_ACCESS_TOKEN=
